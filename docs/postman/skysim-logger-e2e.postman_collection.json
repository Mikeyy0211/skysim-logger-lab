    {
      "name": "9. Logger.Api Query Guest Flow Actions",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200', function() {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Response has items array', function() {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.have.property('items');",
              "    pm.expect(jsonData.items).to.be.an('array');",
              "});",
              "",
              "pm.test('Actions have correct flowId', function() {",
              "    var jsonData = pm.response.json();",
              "    if (jsonData.items && jsonData.items.length > 0) {",
              "        jsonData.items.forEach(function(item) {",
              "            pm.expect(item.flowId).to.eql(pm.collectionVariables.get('guest_flow_id'));",
              "        });",
              "    }",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "auth": {
        "type": "bearer",
        "bearer": [{ "key": "token", "value": "{{access_token}}", "type": "string" }]
      },
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{logger_api_base_url}}/api/log-flows/{{guest_flow_id}}/actions",
          "host": ["{{logger_api_base_url}}"],
          "path": ["api", "log-flows", "{{guest_flow_id}}", "actions"]
        },
        "description": "Retrieves all log actions for the guest checkout flow."
      },
      "response": []
