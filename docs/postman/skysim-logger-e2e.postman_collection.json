              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "auth": {
        "type": "bearer",
        "bearer": [{ "key": "token", "value": "{{access_token}}", "type": "string" }]
      },
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{logger_api_base_url}}/api/log-flows/{{guest_flow_id}}",
          "host": ["{{logger_api_base_url}}"],
          "path": ["api", "log-flows", "{{guest_flow_id}}"]
        },
        "description": "Retrieves detailed information for the guest checkout flow by its flowId."
      },
      "response": []
    },
